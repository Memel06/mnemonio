{
  "name": "@memel06/mnemonio",
  "version": "0.1.1",
  "description": "Persistent structured memory layer for LLM agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "mnemonio": "./dist/cli.js",
    "mnemonio-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "agent",
    "memory",
    "persistent",
    "mcp",
    "ai"
  ],
  "author": "Memel06",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Memel06/mnemonio.git"
  },
  "bugs": {
    "url": "https://github.com/Memel06/mnemonio/issues"
  },
  "homepage": "https://github.com/Memel06/mnemonio#readme",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "yaml": "^2.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
